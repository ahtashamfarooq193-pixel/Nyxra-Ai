PORT=8080
GEMINI_API_KEY=your_gemini_api_key_here
POLLINATIONS_API_KEY=optional_pollinations_key

# Comma-separated list for key rotation
GROQ_API_KEYS=gsk_xxx,gsk_yyy
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback providers
MISTRAL_API_KEYS=key1,key2
MISTRAL_MODEL=open-mistral-7b
CLOUDFLARE_TOKEN=your_token
CLOUDFLARE_ACCOUNT_ID=your_id

# Pollinations Image settings
POLLINATIONS_IMAGE_BASE_URL=https://image.pollinations.ai/prompt
POLLINATIONS_IMAGE_MODEL=gemini
POLLINATIONS_IMAGE_WIDTH=1024
POLLINATIONS_IMAGE_HEIGHT=1024
